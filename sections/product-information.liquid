{% render 'expose-pricing-data' %}

<form id="ProductForm" class="product-form" method="post" action="/cart/add">
  <!-- Fabric & Colour Modal Trigger -->
  <button type="button" id="open-fabric-colour-modal" class="product-form__modal-trigger">Choose Fabric & Colour</button>

  <!-- Modal for Fabric & Colour -->
  <div id="fabric-colour-modal" class="product-form__modal" style="display:none;">
    <div class="product-form__modal-content">
      <h2>Choose Fabric</h2>
      <div class="product-form__swatches" id="fabric-swatches">
        {% for value in product.options_by_name['Fabric'].values %}
          <div class="swatch" data-value="{{ value }}">{{ value }}</div>
        {% endfor %}
      </div>
      <h2>Choose Colour</h2>
      <div class="product-form__swatches" id="colour-swatches">
        {% for value in product.options_by_name['Colour'].values %}
          <div class="swatch" data-value="{{ value }}">{{ value }}</div>
        {% endfor %}
      </div>
      <button type="button" id="close-fabric-colour-modal">Confirm choices</button>
    </div>
  </div>

  <!-- Width Selector (from metafield) -->
  <label for="WidthSelector">Width</label>
  <select id="WidthSelector" name="width">
    {% assign widths = product.metafields.custom.widths | split: ',' %}
    {% for width in widths %}
      <option value="{{ width | strip }}">{{ width | strip }}</option>
    {% endfor %}
  </select>

  <!-- Drop Selector (from variants) -->
  <label for="DropSelector">Drop</label>
  <select id="DropSelector" name="drop">
    {% for value in product.options_by_name['Drop'].values %}
      <option value="{{ value }}">{{ value }}</option>
    {% endfor %}
  </select>

  <!-- Panels is hidden, handled in JS only -->

  <!-- Quantity Selector -->
  <div class="product-form__quantity">
    <button type="button" class="quantity-decrement">-</button>
    <input type="number" name="quantity" value="1" min="1" class="quantity-input" />
    <button type="button" class="quantity-increment">+</button>
  </div>

  <!-- Add to Cart Button -->
  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
  <button type="submit" class="add-to-cart-button">Add to cart</button>
  <button type="button" class="buy-now-button">Buy it now</button>
</form>

<script>
// Modal open/close logic
(function() {
  var openBtn = document.getElementById('open-fabric-colour-modal');
  var closeBtn = document.getElementById('close-fabric-colour-modal');
  var modal = document.getElementById('fabric-colour-modal');
  if (openBtn && closeBtn && modal) {
    openBtn.addEventListener('click', function() { modal.style.display = 'block'; });
    closeBtn.addEventListener('click', function() { modal.style.display = 'none'; });
  }
})();
</script>

<style>
.product-form { max-width: 400px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; }
.product-form__modal { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.product-form__modal-content { background: #fff; padding: 2rem; border-radius: 8px; min-width: 300px; }
.product-form__swatches { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
.swatch { width: 48px; height: 48px; background: #eee; display: flex; align-items: center; justify-content: center; border-radius: 4px; cursor: pointer; border: 2px solid transparent; }
.swatch.selected { border-color: #000; }
.product-form__quantity { display: flex; align-items: center; gap: 0.5rem; }
.quantity-input { width: 48px; text-align: center; }
.add-to-cart-button, .buy-now-button { width: 100%; padding: 1rem; font-size: 1rem; border: none; border-radius: 4px; background: #000; color: #fff; cursor: pointer; margin-bottom: 0.5rem; }
.buy-now-button { background: #222; }
</style>
